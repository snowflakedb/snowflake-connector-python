            }
          }
        ]
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "jsonBody": {
          "data": null,
          "code": "390144",
          "message": "JWT token is invalid.",
          "success": false,
          "headers": null
        }
      }
    }
  ]
}
